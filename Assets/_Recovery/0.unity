  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "La Leucemia felina es una enfermedad viral que puede afectar a gatos de
    todas las edades, aunque es m\xE1s com\xFAn en gatos j\xF3venes. Es causada por
    un virus que afecta principalmente el sistema inmunol\xF3gico y la sangre. Se
    transmite principalmente por el contacto directo con fluidos de un gato infectado,
    como saliva, sangre o secreciones, especialmente a trav\xE9s del acicalamiento,
    mordeduras o el uso compartido de objetos como platos y bebederos."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
